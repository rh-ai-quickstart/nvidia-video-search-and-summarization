{
  "name": "vst-ui-ts",
  "author": "Prakhar Shukla",
  "main": "electron-main.js",
  "private": true,
  "version": "1.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:analyze": "tsc && ANALYZE=true vite build",
    "build:compressed": "tsc && COMPRESS=true vite build",
    "build:all": "npm run build && npm run build:compressed",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0 --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron": "wait-on tcp:5173 && electron .",
    "install:link": "chmod +x ./scripts/install-link.sh && ./scripts/install-link.sh"
  },
  "build": {
    "extends": null,
    "files": [
      "dist/**/*",
      "electron-main.js"
    ],
    "directories": {
      "buildResources": "assets"
    }
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.3.0",
    "@mui/material": "^6.3.0",
    "@mui/x-date-pickers": "^7.23.3",
    "@toolpad/core": "^0.11.0",
    "axios": "^1.7.9",
    "cron-validate": "^1.4.5",
    "cronstrue": "^2.52.0",
    "d3-scale": "^4.0.2",
    "date-fns": "^2.30.0",
    "electron-is-dev": "^3.0.1",
    "framer-motion": "^11.15.0",
    "konva": "^9.2.3",
    "mathjs": "^14.6.0",
    "moment-timezone": "^0.5.46",
    "notistack": "^3.0.2",
    "react": "^18.3.1",
    "react-apexcharts": "^1.7.0",
    "react-compound-slider": "^3.4.0",
    "react-dom": "^18.3.1",
    "react-konva": "^18.2.10",
    "react-router-dom": "^6.28.1",
    "react-sparklines": "^1.7.0",
    "sass": "^1.83.0",
    "scss": "^0.2.4",
    "store2": "^2.14.4",
    "uuid": "^11.0.5",
    "vst-streaming-lib": "file:../streaming-lib",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/react-sparklines": "^1.7.5",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.16",
    "prettier": "^3.6.1",
    "rollup-plugin-visualizer": "^5.14.0",
    "terser": "^5.39.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vite-plugin-compression2": "^1.3.3"
  }
}
