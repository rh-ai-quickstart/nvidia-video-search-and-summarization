# SonarLint Configuration for Generic Script
# Source this file before running the generic script: source sonar-lint.env

# Project Configuration
export PROJECT_NAME="vms_shim"
export SOURCE_DIRS="src"
export DOCKERFILE_PATH="cicd_files/x86_64/Dockerfile.app"

# Docker Images (NVIDIA-specific - mirrors Makefile)
export DOCKER_IMAGE_X86="gitlab-master.nvidia.com:5005/l4tmm/vms_shim/cicd_images:x86_24.04_build_cuda12.8.1"
export DOCKER_IMAGE_CROSS="gitlab-master.nvidia.com:5005/l4tmm/vms_shim/cicd_images:jetson_cross_compiler_dev-main"

# Build Configuration
export MAKE_PARALLEL_JOBS="12"
export BUILD_VARIANTS="x86 cc1 cc2"

# Output Organization
export SONAR_OUTPUT_DIR="sonar-databases"
export UNIFIED_DIR="$SONAR_OUTPUT_DIR/unified"

echo "🔧 SonarLint environment loaded"
echo "📋 Project: $PROJECT_NAME"
echo "🐳 Cross-compile image: $DOCKER_IMAGE_CROSS"
echo "💡 Usage: vms_shim/tools/sonar-lint/generate_compile_command.sh --all --unified"