HOST_IP=<Host IP> ### change me

# You can config the VST configs from below (Must be absolute path)
VST_CONFIG_PATH=/home/ubuntu/vms_shim/deployment/stream-processing/docker-compose/configs ### change me

# You can config the VST volume from below (Must be absolute path)
VST_VOLUME=/home/ubuntu/vms_shim/deployment/stream-processing/docker-compose/vst_volume ### change me

###################### Stream-Processor service #####################################
VST_STREAM_PROCESSOR_IMAGE=nvcr.io/nvidia/vss-core/vss-vios-streamprocessing:3.2.0

STREAM_PROCESSOR_HTTP_PORT_1=30001
# [Pod 2 disabled] Uncomment to enable second stream-processing pod
#STREAM_PROCESSOR_HTTP_PORT_2=30002

RTSP_SERVER_PORT_1=30554 ### change me if you want to stream more than 100 streams per pod
# [Pod 2 disabled] Uncomment to enable RTSP server for second pod
#RTSP_SERVER_PORT_2=30564 ### change me if you want to stream more than 100 streams per pod

STREAM_PROCESSOR_MODULE_ENDPOINT=http://${HOST_IP}:10000
##########################################################################

###################### Base Infrastructure Images ########################
POSTGRES_IMAGE=postgres:17.9-alpine
NGINX_IMAGE=nvcr.io/nvidia/vss-core/vss-vios-ingress:3.2.0
REDIS_IMAGE=redis:8.6.2-alpine

# NGINX Configuration Mode
# NGINX_MODE=vst  → uses nginx-vst.conf (timelines NOT routed to sensor, stays with storage service)
# NGINX_MODE=mms  → uses nginx-mms.conf (timelines routed to sensor service)
NGINX_MODE=vst
VST_INGRESS_ENDPOINT=${HOST_IP}:30888/vst
##########################################################################

###################### SDR and Supporting Images #########################
SDR_IMAGE=nvcr.io/nvidia/vss-core/sdr:3.1.0
ENVOY_PROXY_IMAGE=nvcr.io/nvidia/vss-core/envoy-proxy:3.1.0

#Number of stream support per POD
MAX_STREAMS_PER_POD=100
##########################################################################

###################### Monitoring Images #####################
PROMETHEUS_IMAGE=prom/prometheus:v3.11.3
GRAFANA_IMAGE=grafana/grafana:13.0

SENSOR_PROMETHEUS_PORT=8080
STREAM_PROCESSOR_PROMETHEUS_PORT_1=8087
# [Pod 2 disabled] Uncomment to enable Prometheus metrics for second pod
#STREAM_PROCESSOR_PROMETHEUS_PORT_2=8088
##########################################################################

###################### SDR Base IDs ######################################
STREAMPROCESSING_BASE_ID=1
##########################################################################

###################### VST Paths and Data Configuration ##################
VST_DATA_PATH=${VST_VOLUME}/vst_data
VST_VIDEO_STORAGE_PATH=${VST_VOLUME}/vst_video

# VST storage size settings in MB
VST_VIDEO_STORAGE_SIZE_MB=100000

VST_LOGS=${VST_DATA_PATH}/logs
VST_TEMP_FILES_PATH=${VST_VOLUME}/vst_temp_files
CLIP_STORAGE_PATH=${VST_VOLUME}/clip_storage
##########################################################################

###################### Database Configuration ############################
CENTRALIZE_DB_NAME=nvcentralizedb
CENTRALIZE_DB_USERNAME=vst
CENTRALIZE_DB_PASSWORD=nvidia123
CENTRALIZE_DB_PORT=5432
CENTRALIZE_DB_HOSTADDR=${HOST_IP}
##########################################################################

###################### SENSOR service #####################################
VST_SENSOR_IMAGE=nvcr.io/nvidia/vss-core/vss-vios-sensor:3.2.0
# vst_rtsp, onvif, milestone_onvif
VST_ADAPTOR=vst_rtsp

SENSOR_HTTP_PORT=30000
SENSOR_MODULE_ENDPOINT=http://${HOST_IP}:${SENSOR_HTTP_PORT}
##########################################################################

###################### Redis Configuration ###############################
REDIS_HOSTADDR=${HOST_IP}
REDIS_PORT=6379
REDIS_MSG_KEY=vst_events
##########################################################################

###################### Kafka Configuration ###############################
KAFKA_BOOTSTRAP_URL=${HOST_IP}:9092
KAFKA_MSG_KEY=sensor.id
##########################################################################

###################### Additional Packages Configuration #################
# Additional packages are needed for certain use cases (e.g., audio, software encoding-decoding, video downloading).
# To install these packages, set VST_INSTALL_ADDITIONAL_PACKAGES=true.
VST_INSTALL_ADDITIONAL_PACKAGES=true
##########################################################################
