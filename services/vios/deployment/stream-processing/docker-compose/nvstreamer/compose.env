#Nvstreamer image
NVSTREAMER_IMAGE=nvcr.io/nvstaging/vss-core/vss-vios-nvstreamer:2.1.0-26.05.2.1

NVSTREAMER_CONFIG=./configs

NVSTREAMER_HTTP_PORT_1=31000
NVSTREAMER_HTTP_PORT_2=31001
NVSTREAMER_HTTP_PORT_3=31002
NVSTREAMER_HTTP_PORT_4=31003
NVSTREAMER_HTTP_PORT_5=31004

NVSTREAMER_RTSP_PORT_1=31554
NVSTREAMER_RTSP_PORT_2=31564
NVSTREAMER_RTSP_PORT_3=31574
NVSTREAMER_RTSP_PORT_4=31584
NVSTREAMER_RTSP_PORT_5=31594

# Note: Please change the nvstreamer videos path if you want to use your videos
NVSTREAMER_VIDEO_1=/home/ubuntu/vms_shim/deployment/stream-processing/docker-compose/nvstreamer/videos/nvstreamer-1 #change me
NVSTREAMER_VIDEO_2=/home/ubuntu/vms_shim/deployment/stream-processing/docker-compose/nvstreamer/videos/nvstreamer-2 #change me
NVSTREAMER_VIDEO_3=/home/ubuntu/vms_shim/deployment/stream-processing/docker-compose/nvstreamer/videos/nvstreamer-3 #change me
NVSTREAMER_VIDEO_4=/home/ubuntu/vms_shim/deployment/stream-processing/docker-compose/nvstreamer/videos/nvstreamer-4 #change me
NVSTREAMER_VIDEO_5=/home/ubuntu/vms_shim/deployment/stream-processing/docker-compose/nvstreamer/videos/nvstreamer-5 #change me

# Note: Each nvstreamer instances supports ~100 streams. Please configure as per your requirements.
# Default 1 nvstreamer instance is configured.
COMPOSE_PROFILES=nvstreamer-1
#COMPOSE_PROFILES=nvstreamer-1,nvstreamer-2,nvstreamer-3,nvstreamer-4,nvstreamer-5

# Additional packages are needed for certain use cases (e.g., audio, software encoding-decoding, file upload).
# To install these packages, set NVSTREAMER_INSTALL_ADDITIONAL_PACKAGES=true.
NVSTREAMER_INSTALL_ADDITIONAL_PACKAGES=true