{
	"mqtt": {
		"host": "localhost",
		"port": 1883,
		"clientId": "mdx-spatial-analytics-3d-app",
		"keepAliveSec": 60,
		"consumer": {
			"qos": 1,
			"maxPollCount": 1000,
			"pollTimeoutSec": 0.01
