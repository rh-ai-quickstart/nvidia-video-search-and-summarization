{
	"kafka": {
		"brokers": "localhost:9092",
		"topics": [
			{
				"name": "raw",
				"value": "mdx-raw"
			},
			{
				"name": "behavior",
				"value": "mdx-behavior"
			},
			{
				"name": "frames",
				"value": "mdx-frames"
			},
			{
				"name": "notification",
				"value": "mdx-notification"
			},
			{
				"name": "events",
				"value": "mdx-events"
			}
		],
		"consumer": {
			"autoOffsetReset": "latest",
			"enableAutoCommit": false,
			"maxPollIntervalMs": 900000,
			"maxPartitionFetchBytes": 10485760,
			"fetchMaxBytes": 104857600,
			"maxPollRecords": 10000,
			"timeout": 0.01
		},
		"producer": {
			"lingerMs": 0
		},
		"group": "mdx-spatial-analytics-2d-app"
	},
	"sensors": [
		{
			"id": "default",
			"configs": [
				{
					"name": "proximityDetectionEnable",
					"value": "true"
				},
				{
					"name": "proximityDetectionThreshold",
					"value": "1.8"
				},
				{
					"name": "proximityDetectionCenterClasses",
					"value": "[\"Person\", \"Object\"]"
				},
				{
					"name": "proximityDetectionSurroundingClasses",
					"value": "[\"Person\", \"Object\"]"
				},
				{
					"name": "tripwireMinPoints",
					"value": "4"
				}
			]
		}
	],
	"app": [
		{
			"name": "behaviorWatermarkSec",
			"value": "30"
		},
		{
			"name": "behaviorStateTimeout",
			"value": "10"
		},
		{
			"name": "behaviorMaxPoints",
			"value": "200"
		},
		{
			"name": "playbackLoop",
			"value": "10000"
		},
		{
			"name": "playbackFilterEmptyObjects",
			"value": "true"
		},
		{
			"name": "playbackStartUpDelaySec",
			"value": "90"
		},
		{
			"name": "coordinateSystem",
			"value": "image"
		},
		{
			"name": "sourceType",
			"value": "kafka"
		},
		{
			"name": "sinkType",
			"value": "kafka"
		},
		{
			"name": "numWorkersForBehaviorCreation",
			"value": "2"
		},
		{
			"name": "numWorkersForFrameEnhancement",
			"value": "2"
		}
	]
}
