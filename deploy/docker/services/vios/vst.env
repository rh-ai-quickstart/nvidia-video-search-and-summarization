# =============================================================================
# VST shared environment — used by foundational, initiator, and sdr includes
# =============================================================================

VST_VOLUME=${VSS_DATA_DIR}/data_log/vst
VST_CONFIG_PATH=${VSS_APPS_DIR}/services/vios/configs
VST_DATA_PATH=${VST_VOLUME}/vst_data
VST_VIDEO_STORAGE_PATH=${VST_VOLUME}/vst_video
VST_TEMP_FILES_PATH=${VST_VOLUME}/temp_files
VST_LOGS=${VST_DATA_PATH}/logs
CLIP_STORAGE_PATH=${VST_VOLUME}/clip_storage
VST_NGINX_MODE=vst
VST_INSTALL_ADDITIONAL_PACKAGES=true

# VST Adaptor type. Valid values: vst_rtsp, milestone_onvif
VST_ADAPTOR=vst_rtsp

# VST db details
CENTRALIZE_DB_NAME=nvcentralizedb
CENTRALIZE_DB_USERNAME=vst

# VST storage size settings in MB
VST_VIDEO_STORAGE_SIZE_MB=100000

# Service HTTP ports
SENSOR_HTTP_PORT=30000
STREAM_PROCESSOR_HTTP_PORT=30001

# Readiness URL for the blueprint/profile configurator when it is not defined in the same compose project; sensor-bp-wait-bp-configurator polls it so VST services avoid depends_on on external configurator workloads.
BP_CONFIGURATOR_READYZ_URL=http://127.0.0.1:5001/readyz
SENSOR_BP_WAIT_BP_CONFIGURATOR_MAX_SEC=300

# sensor-bp-wait-storage polls STORAGE_HTTP_PORT until it accepts connections so VST services avoid depends_on on storage HTTP workloads defined outside this directory.
SENSOR_BP_WAIT_STORAGE_MAX_SEC=300

# RTSP port
RTSP_SERVER_PORT=30554

# Module endpoints
SENSOR_MODULE_ENDPOINT=http://localhost:30000
STREAM_PROCESSOR_MODULE_ENDPOINT=http://localhost:10000

# VST ingress
VST_INGRESS_HTTP_PORT=30888
VST_INGRESS_ENDPOINT=${HOST_IP}:30888/vst

# Redis / Kafka
REDIS_HOSTADDR=localhost
REDIS_PORT=6379
REDIS_MSG_KEY=vst.event
KAFKA_BOOTSTRAP_URL=localhost:9092
KAFKA_MSG_KEY=sensor.id

###################### VST Images ########################
VST_SENSOR_IMAGE=nvcr.io/nvidia/vss-core/vss-vios-sensor:${VST_SENSOR_IMAGE_TAG}
VST_STREAM_PROCESSOR_IMAGE=nvcr.io/nvidia/vss-core/vss-vios-streamprocessing:${VST_STREAM_PROCESSOR_IMAGE_TAG}
NGINX_IMAGE=nvcr.io/nvidia/vss-core/vss-vios-ingress:${VST_INGRESS_IMAGE_TAG}

POSTGRES_IMAGE=postgres:17.9-alpine
